<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp"
        mc:Ignorable="d"
        Title="Телефонная книга (WPF) — Вариант 16"
        Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        MinWidth="900" MinHeight="500">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.35*"/>
            <ColumnDefinition Width="0.65*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Левая панель: форма ввода (в Expander) -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5"
                Background="#F9F9F9" Margin="0,0,5,0">
            <Expander Header="Добавить / Редактировать контакт"
                      IsExpanded="True" Margin="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="5">
                        <!-- Фамилия -->
                        <Label Content="Фамилия:" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtLastName" Height="28" Margin="0,0,0,10"/>

                        <!-- Имя -->
                        <Label Content="Имя:" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtFirstName" Height="28" Margin="0,0,0,10"/>

                        <!-- Отчество -->
                        <Label Content="Отчество:" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtPatronymic" Height="28" Margin="0,0,0,10"/>

                        <!-- Организация -->
                        <Label Content="Организация:" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtOrganization" Height="28" Margin="0,0,0,10"/>

                        <!-- Телефон / e-mail -->
                        <Label Content="Телефон / e-mail:" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtPhone" Height="28" Margin="0,0,0,10"/>

                        <!-- Кнопки действий -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="btnAdd" Content="Добавить"
                                    Height="32" Margin="2" Click="BtnAdd_Click"/>
                            <Button Grid.Column="1" x:Name="btnUpdate" Content="Изменить"
                                    Height="32" Margin="2" Click="BtnUpdate_Click"/>
                            <Button Grid.Column="2" x:Name="btnClearForm" Content="Очистить"
                                    Height="32" Margin="2" Click="BtnClearForm_Click"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Expander>
        </Border>

        <!-- Правая панель: таблица и кнопки управления -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Таблица (в ScrollViewer) -->
            <Border Grid.Row="0"
                    BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5"
                    Background="#F9F9F9" Margin="0,0,0,5">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <DataGrid x:Name="dgContacts"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              SelectionChanged="DgContacts_SelectionChanged"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              ColumnWidth="*"
                              MinColumnWidth="80"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*" MinWidth="100"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*" MinWidth="100"/>
                            <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="*" MinWidth="100"/>
                            <DataGridTextColumn Header="Организация" Binding="{Binding Organization}" Width="*" MinWidth="120"/>
                            <DataGridTextColumn Header="Телефон / e-mail" Binding="{Binding Phone}" Width="*" MinWidth="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </Border>

            <!-- Кнопки управления (в Expander) -->
            <Expander Grid.Row="1" Header="Управление данными" IsExpanded="True" Margin="0,5,0,0">
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5"
                        Background="#F9F9F9" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="btnLoadXml" Content="Загрузить из XML"
                                Height="32" Margin="5,0" Click="BtnLoadXml_Click"/>
                        <Button Grid.Column="1" x:Name="btnSaveXml" Content="Сохранить в XML"
                                Height="32" Margin="5,0" Click="BtnSaveXml_Click"/>
                        <Button Grid.Column="2" x:Name="btnDeleteSelected" Content="Удалить выбранного"
                                Height="32" Margin="5,0" Click="BtnDeleteSelected_Click"/>
                        <Button Grid.Column="3" x:Name="btnClearTable" Content="Очистить таблицу"
                                Height="32" Margin="5,0" Click="BtnClearTable_Click"/>
                    </Grid>
                </Border>
            </Expander>
        </Grid>
    </Grid>
</Window>